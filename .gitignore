## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/

# SQLite databases
*.db
*.db-shm
*.db-wal

# Sensitive appsettings (optional, if you want to keep Development settings secret)
appsettings.Development.json
appsettings.Production.json

# Gemini Agent files
.agent/
.system_generated/
