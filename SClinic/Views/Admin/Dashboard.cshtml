@{
    ViewData["Title"] = "Báo cáo";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";

    var todayRevenue    = (decimal)(ViewBag.TodayRevenue    ?? 0m);
    var waitingCount    = (int)    (ViewBag.WaitingCount    ?? 0);
    var pendingInvoices = (int)    (ViewBag.PendingInvoices ?? 0);
    var lowStockCount   = (int)    (ViewBag.LowStockCount   ?? 0);
    var revenueStr      = todayRevenue.ToString("N0");
}

<!-- KPI Cards -->
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 border-l-4 border-l-brand-primary">
        <p class="text-sm text-slate-500 font-semibold mb-1">Doanh thu hôm nay</p>
        <h3 class="text-2xl font-extrabold text-slate-900">@revenueStr₫</h3>
        <p class="text-xs text-emerald-600 mt-2 font-medium">↑ Hôm nay</p>
    </div>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 border-l-4 border-l-blue-500">
        <p class="text-sm text-slate-500 font-semibold mb-1">Khách chờ khám</p>
        <h3 class="text-2xl font-extrabold text-slate-900">@waitingCount.ToString("D2") <span class="text-sm font-normal text-slate-400">người</span></h3>
        <p class="text-xs text-slate-500 mt-2">Đang ở sảnh chờ</p>
    </div>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 border-l-4 border-l-amber-500">
        <p class="text-sm text-slate-500 font-semibold mb-1">Hóa đơn chờ thu</p>
        <h3 class="text-2xl font-extrabold text-slate-900">@pendingInvoices <span class="text-sm font-normal text-slate-400">HĐ</span></h3>
        <p class="text-xs text-amber-600 mt-2 font-medium">Cần xử lý</p>
    </div>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 border-l-4 border-l-red-400">
        <p class="text-sm text-slate-500 font-semibold mb-1">Thuốc sắp hết</p>
        <h3 class="text-2xl font-extrabold text-slate-900">@lowStockCount.ToString("D2") <span class="text-sm font-normal text-slate-400">loại</span></h3>
        <p class="text-xs text-red-500 mt-2 font-medium">Dưới 10 sản phẩm</p>
    </div>
</div>

<!-- Chart & Rankings Row 1 -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <!-- Revenue Chart -->
    <div class="lg:col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col relative">
        <div class="flex justify-between items-center mb-6">
            <h3 class="text-lg font-bold text-slate-800" id="chart-title">Doanh thu 7 ngày gần nhất</h3>
            <select id="range-select" class="border border-slate-200 rounded-lg p-2 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none">
                <option value="week">Tuần này</option>
                <option value="month">Tháng này</option>
            </select>
        </div>
        <div class="flex-1 w-full min-h-[300px]">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Top Services -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
        <h3 class="text-lg font-bold text-slate-800 mb-6">🥇 Dịch vụ & Gói Liệu Trình Bán Chạy</h3>
        <div id="top-services-app">
            <div v-if="loading" class="text-slate-400 text-sm text-center py-6">⏳ Đang tải…</div>
            <div v-else-if="items.length === 0" class="text-slate-400 text-sm text-center py-6">Chưa có dữ liệu.</div>
            <ul v-else class="space-y-4">
                <li v-for="(item, i) in items" :key="i" class="flex justify-between items-center pb-3 border-b border-slate-100 last:border-0 last:pb-0">
                    <div class="flex items-center gap-3">
                        <div :class="[
                            'w-8 h-8 rounded-full flex items-center justify-center font-bold text-xs',
                            i===0?'bg-brand-primary/10 text-brand-primary':i===1?'bg-slate-100 text-slate-600':'bg-amber-50 text-amber-600'
                        ]">[[ i+1 ]]</div>
                        <div>
                            <p class="text-sm font-bold text-slate-800">[[ item.name ]]</p>
                            <p class="text-xs text-slate-500">[[ item.type ]]</p>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-sm font-extrabold" :class="i===0?'text-brand-primary':'text-slate-800'">[[ item.count ]]</p>
                        <p class="text-xs text-slate-400">lượt bán</p>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>

<!-- Detailed Stats Row 2 -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 pb-12" id="stats-app">
    <!-- Doctor Performance -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center">
            <h3 class="font-bold text-slate-800">👨‍⚕️ Hiệu Suất Bác Sĩ Tháng Này</h3>
        </div>
        <div v-if="doctorLoading" class="p-8 text-center text-slate-400">⏳ Đang tải…</div>
        <div v-else-if="doctors.length === 0" class="p-8 text-center text-slate-400">Chưa có dữ liệu tháng này.</div>
        <table v-else class="w-full text-left text-sm">
            <thead class="bg-slate-50/50 text-slate-500 text-xs">
                <tr>
                    <th class="p-4 font-semibold">Tên Bác Sĩ</th>
                    <th class="p-4 font-semibold text-center">Số Ca</th>
                    <th class="p-4 font-semibold text-right">Doanh Thu</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <tr v-for="(d, i) in doctors" :key="d.doctorId" class="hover:bg-slate-50 transition-colors">
                    <td class="p-4 font-bold text-slate-800">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center text-brand-primary font-bold text-sm">
                                [[ d.fullName.charAt(0) ]]
                            </div>
                            [[ d.fullName ]]
                            <span v-if="i===0" class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded ml-1">Top 1</span>
                        </div>
                    </td>
                    <td class="p-4 text-center font-medium text-slate-600">[[ d.appointmentCount ]]</td>
                    <td class="p-4 text-right font-bold" :class="i===0?'text-brand-primary':'text-slate-700'">
                        [[ d.revenue.toLocaleString('vi-VN') ]]đ
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Staff KPIs -->
    <div class="bg-white rounded-2xl shadow-sm border border-slate-200">
        <div class="p-5 border-b border-slate-100">
            <h3 class="font-bold text-slate-800">👥 KPI Tháng Này</h3>
        </div>
        <div v-if="kpiLoading" class="p-8 text-center text-slate-400">⏳ Đang tải…</div>
        <div v-else class="p-6 grid grid-cols-2 gap-6">
            <div class="space-y-4">
                <div class="bg-blue-50/50 p-4 rounded-xl border border-blue-100 border-l-4 border-l-blue-500">
                    <p class="text-xs text-blue-800 font-bold mb-1 uppercase tracking-wider">Tổng Bệnh Nhân</p>
                    <h4 class="text-2xl font-extrabold text-slate-900">[[ kpi.patientsTotal ]] <span class="text-sm font-normal text-slate-500">người</span></h4>
                    <p class="text-xs text-slate-500 mt-2">Tổng hồ sơ trong hệ thống</p>
                </div>
                <div class="bg-amber-50/50 p-4 rounded-xl border border-amber-100 border-l-4 border-l-amber-500">
                    <p class="text-xs text-amber-800 font-bold mb-1 uppercase tracking-wider">Lịch Hẹn Tháng</p>
                    <h4 class="text-2xl font-extrabold text-slate-900">[[ kpi.appointmentsMonth ]] <span class="text-sm font-normal text-slate-500">lượt</span></h4>
                    <p class="text-xs text-slate-500 mt-2">Tất cả lịch trong tháng này</p>
                </div>
            </div>
            <div>
                <div class="bg-emerald-50/50 p-4 rounded-xl border border-emerald-100 border-l-4 border-l-emerald-500 h-full flex flex-col justify-center">
                    <div class="absolute-0 top-4 right-4"></div>
                    <p class="text-xs text-emerald-800 font-bold mb-1 uppercase tracking-wider">Hóa Đơn Đã Thu</p>
                    <h4 class="text-3xl font-extrabold text-emerald-700">[[ kpi.invoicesPaid ]] <span class="text-base font-normal text-slate-500">HĐ</span></h4>
                    <div class="w-full bg-emerald-200 rounded-full h-1.5 mt-4 mb-2">
                        <div class="bg-emerald-600 h-1.5 rounded-full transition-all" :style="{width: kpi.collectionRate + '%'}"></div>
                    </div>
                    <p class="text-xs text-slate-500 font-medium">Tỷ lệ thu: [[ kpi.collectionRate ]]% ([[ kpi.invoicesTotal ]] tổng)</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('revenueChart');
            if (!ctx) return;

            let chartInstance = null;

            const buildChart = (labels, values) => {
                if (chartInstance) chartInstance.destroy();
                chartInstance = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [{
                            label: 'Doanh Thu (triệu VNĐ)',
                            data: values,
                            backgroundColor: values.map((_, i) => i === values.length - 1 ? '#0f766e' : '#99f6e4'),
                            borderRadius: 6,
                            borderSkipped: false,
                            barPercentage: 0.6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                padding: 12,
                                displayColors: false,
                                callbacks: { label: c => c.raw.toLocaleString() + ' Triệu VNĐ' }
                            }
                        },
                        scales: {
                            y: { beginAtZero: true, border: { display: false }, grid: { color: '#f1f5f9', drawTicks: false }, ticks: { color: '#64748b', padding: 10 } },
                            x: { border: { display: false }, grid: { display: false }, ticks: { color: '#64748b', font: { weight: 'bold' } } }
                        }
                    }
                });
            };

            const loadChart = async (range) => {
                try {
                    const res  = await fetch(`/api/invoicesapi/revenue-chart?range=${range}`);
                    const data = await res.json();
                    const labels = data.map(d => d.label);
                    const values = data.map(d => d.value);
                    buildChart(labels, values);
                    document.getElementById('chart-title').textContent =
                        range === 'month' ? 'Doanh thu 30 ngày gần nhất' : 'Doanh thu 7 ngày gần nhất';
                } catch {
                    // Fallback to static data if API fails
                    buildChart(['T5','T6','T7','CN','T2','T3','Hôm nay'],
                               [3.2, 6.5, 9.1, 14.2, 2.5, 11.8, @(todayRevenue / 1000000)]);
                }
            };

            document.getElementById('range-select').addEventListener('change', e => loadChart(e.target.value));
            loadChart('week');
        });

        // ── Top Services Vue app ──────────────────────────────────────────────
        const { createApp: ca1, ref: r1, onMounted: om1 } = Vue;
        ca1({
            delimiters: ['[[',']]'],
            setup() {
                const items   = r1([]);
                const loading = r1(true);
                om1(async () => {
                    try {
                        const res = await fetch('/api/admin/top-services');
                        items.value = await res.json();
                    } catch { items.value = []; }
                    loading.value = false;
                });
                return { items, loading };
            }
        }).mount('#top-services-app');

        // ── Stats Vue app (doctor perf + KPI) ────────────────────────────────
        const { createApp: ca2, ref: r2, onMounted: om2 } = Vue;
        ca2({
            delimiters: ['[[',']]'],
            setup() {
                const doctors       = r2([]);
                const doctorLoading = r2(true);
                const kpi           = r2({ patientsTotal:0, appointmentsMonth:0, invoicesPaid:0, invoicesTotal:0, collectionRate:0 });
                const kpiLoading    = r2(true);

                om2(async () => {
                    try {
                        const [drRes, kpiRes] = await Promise.all([
                            fetch('/api/admin/doctor-stats'),
                            fetch('/api/admin/kpi-stats'),
                        ]);
                        doctors.value = await drRes.json();
                        kpi.value     = await kpiRes.json();
                    } catch { /* silent */ }
                    doctorLoading.value = false;
                    kpiLoading.value    = false;
                });

                return { doctors, doctorLoading, kpi, kpiLoading };
            }
        }).mount('#stats-app');
    </script>
}
