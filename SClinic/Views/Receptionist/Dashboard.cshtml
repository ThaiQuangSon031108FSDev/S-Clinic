@{
    ViewData["Title"] = "Hàng đợi";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<div id="app">
    <!-- Check-in box -->
    <div class="bg-white border border-teal-200 rounded-2xl px-5 py-4 mb-5 flex items-center gap-4 shadow-sm">
        <div class="w-10 h-10 rounded-xl bg-teal-50 text-teal-600 flex items-center justify-center text-xl flex-shrink-0">📋</div>
        <div class="flex-1">
            <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Check-in bệnh nhân</p>
            <div class="flex gap-2">
                <input v-model="checkinCode" type="text" placeholder="Nhập mã APT-0020 hoặc SĐT..."
                       @@keyup.enter="doCheckin"
                       class="flex-1 text-sm border border-slate-200 rounded-xl px-4 py-2 focus:ring-2 focus:ring-brand-primary focus:outline-none font-mono" />
                <button @@click="doCheckin" :disabled="!checkinCode.trim()"
                        class="px-5 py-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-bold rounded-xl transition-colors disabled:opacity-40">
                    📣 Gọi vào
                </button>
            </div>
            <p v-if="checkinMsg" :class="checkinOk ? 'text-teal-700' : 'text-red-600'" class="text-xs font-semibold mt-1.5">{{ checkinMsg }}</p>
        </div>
    </div>

    <!-- Subheader tabs -->
    <div class="flex gap-3 mb-6">
        <button @@click="view='kanban'" :class="view==='kanban'?'bg-brand-primary text-white shadow-md':'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50'"
                class="px-5 py-2.5 rounded-xl font-semibold text-sm transition-all">
            📋 Kanban Hàng đợi
        </button>
        <button @@click="view='list'" :class="view==='list'?'bg-brand-primary text-white shadow-md':'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50'"
                class="px-5 py-2.5 rounded-xl font-semibold text-sm transition-all">
            📅 Danh sách
        </button>
        <a asp-controller="Receptionist" asp-action="RegisterPatient"
           class="ml-auto bg-slate-900 text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-slate-800 transition-colors">
            + Đăng ký BN mới
        </a>
    </div>

    <!-- KANBAN -->
    <div v-if="view==='kanban'" class="flex gap-6 overflow-x-auto pb-4" style="height:calc(100vh - 240px)">

        <!-- Col 1 -->
        <div class="flex-1 min-w-72 bg-slate-100/60 rounded-2xl border border-slate-200 flex flex-col">
            <div class="p-4 border-b border-slate-200/60 flex justify-between items-center bg-slate-100 rounded-t-2xl">
                <h3 class="font-bold text-slate-700">⏳ Đang chờ khám</h3>
                <span class="bg-slate-200 text-slate-600 text-xs font-bold px-2.5 py-1 rounded-md">[[ pendingList.length ]] Khách</span>
            </div>
            <div class="p-4 flex-1 overflow-y-auto space-y-3">
                <div v-for="p in pendingList" :key="p.id"
                     class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-amber-400 hover:shadow-md transition-shadow">
                    <div class="flex justify-between items-start mb-2">
                        <span class="text-xs font-bold text-slate-400">#STT-[[ String(p.id).padStart(2,'0') ]]</span>
                        <span class="text-xs font-medium text-slate-500">[[ p.time ]]</span>
                    </div>
                    <h4 class="font-bold text-slate-900">[[ p.name ]]</h4>
                    <p class="text-sm text-slate-600 mt-1">[[ p.service ]]</p>
                    <p class="text-xs text-slate-500 mt-2">BS: <b>[[ p.doctor ]]</b></p>
                    <button @@click="callIn(p)"
                            class="mt-3 w-full bg-teal-50 text-teal-700 hover:bg-teal-600 hover:text-white py-2 rounded-lg text-sm font-semibold transition-colors">
                        📣 Gọi vào phòng khám
                    </button>
                </div>
                <div v-if="!pendingList.length" class="text-center text-slate-400 text-sm py-8">Sảnh chờ trống 🎉</div>
            </div>
        </div>

        <!-- Col 2 -->
        <div class="flex-1 min-w-72 bg-teal-50/40 rounded-2xl border border-teal-100 flex flex-col">
            <div class="p-4 border-b border-teal-100 flex justify-between items-center bg-teal-50 rounded-t-2xl">
                <h3 class="font-bold text-teal-700">🩺 Đang Khám / Dịch vụ</h3>
                <span class="bg-teal-200 text-teal-800 text-xs font-bold px-2.5 py-1 rounded-md">[[ activeList.length ]] Khách</span>
            </div>
            <div class="p-4 flex-1 overflow-y-auto space-y-3">
                <div v-for="p in activeList" :key="p.id"
                     class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-teal-500">
                    <span class="text-xs font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded">[[ p.room ]]</span>
                    <h4 class="font-bold text-slate-900 mt-2">[[ p.name ]]</h4>
                    <p class="text-sm text-amber-600 font-medium mt-1">[[ p.service ]]</p>
                    <p class="text-xs text-slate-400 mt-3 flex items-center gap-1.5"><span class="animate-pulse w-2 h-2 bg-amber-400 rounded-full inline-block"></span> BS. đang chẩn đoán...</p>
                    <div class="mt-3 w-full bg-slate-50 border border-slate-100/60 text-slate-400 text-center py-1.5 rounded-lg text-[10px] font-medium leading-tight">
                        Sẽ tự chuyển sang Chờ Thu Ngân <br/>khi Bác Sĩ hoàn tất
                    </div>
                </div>
                <div v-if="!activeList.length" class="text-center text-slate-400 text-sm py-8">Chưa có bệnh nhân</div>
            </div>
        </div>

        <!-- Col 3 -->
        <div class="flex-1 min-w-72 bg-blue-50/30 rounded-2xl border border-blue-100 flex flex-col">
            <div class="p-4 border-b border-blue-100 flex justify-between items-center bg-blue-50 rounded-t-2xl">
                <h3 class="font-bold text-blue-700">💵 Chờ Thu Ngân</h3>
                <span class="bg-blue-200 text-blue-800 text-xs font-bold px-2.5 py-1 rounded-md">[[ cashierList.length ]] Khách</span>
            </div>
            <div class="p-4 flex-1 overflow-y-auto space-y-3">
                <div v-for="inv in cashierList" :key="inv.invoiceId ?? inv._apptId"
                     class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 border-l-4 border-l-blue-500">

                    <!-- Patient name + code -->
                    <div class="flex justify-between items-start mb-3">
                        <div>
                            <h4 class="font-bold text-slate-900">[[ inv.patientName ]]</h4>
                            <p v-if="inv.invoiceId" class="text-[10px] text-slate-400 font-mono mt-0.5">#HD-[[ String(inv.invoiceId).padStart(4,'0') ]]</p>
                        </div>
                        <span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded-full">Chờ thu</span>
                    </div>

                    <!-- Invoice details -->
                    <div class="bg-slate-50 p-3 rounded-lg border border-slate-100">
                        <p class="text-xs font-bold text-slate-500 mb-2 uppercase tracking-wide">Chi tiết dịch vụ</p>
                        <ul class="text-xs space-y-1.5 mb-3">
                            <li v-for="(item, i) in (inv.details || [])" :key="i"
                                class="flex justify-between items-start border-b border-dashed border-slate-200/70 pb-1.5">
                                <span class="flex-1 pr-2">[[ item.quantity ]]× [[ item.name ]]</span>
                                <span class="font-bold text-slate-700">[[ (item.subtotal||0).toLocaleString() ]]đ</span>
                            </li>
                            <li v-if="!inv.details || !inv.details.length" class="text-slate-400 italic text-center py-1">Khám cơ bản (chưa kê thêm dịch vụ)</li>
                        </ul>
                        <div class="flex justify-between items-center font-semibold text-slate-800 pt-1">
                            <span class="text-sm">Tổng cần thu:</span>
                            <span class="text-base font-extrabold text-brand-primary">[[ (inv.totalAmount||0).toLocaleString() ]]đ</span>
                        </div>
                    </div>

                    <!-- Payment input — must fill before confirming -->
                    <div v-if="!inv._paid" class="mt-3 space-y-2">
                        <label class="text-xs font-bold text-slate-600">💵 Khách đưa (đồng):</label>
                        <div class="flex gap-2">
                            <input type="number" v-model.number="inv._received" min="0"
                                   :placeholder="(inv.totalAmount||0) + ''"
                                   class="flex-1 border border-slate-200 rounded-lg px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                        </div>
                        <!-- Change display -->
                        <div v-if="inv._received > 0" class="flex justify-between text-xs px-1">
                            <span class="text-slate-500">Tiền thừa trả lại:</span>
                            <span :class="(inv._received - (inv.totalAmount||0)) >= 0 ? 'text-emerald-600 font-bold' : 'text-red-500 font-bold'">
                                [[ Math.max(0, inv._received - (inv.totalAmount||0)).toLocaleString() ]]đ
                            </span>
                        </div>
                        <!-- Insufficient warning -->
                        <p v-if="inv._received > 0 && inv._received < (inv.totalAmount||0)"
                           class="text-xs text-red-500 font-medium">⚠️ Chưa đủ số tiền cần thu</p>

                        <button @@click="payInvoice(inv)"
                                :disabled="paying || !(inv._received > 0 && inv._received >= (inv.totalAmount||0)) && (inv.totalAmount||0) > 0"
                                class="w-full mt-1 bg-emerald-600 text-white py-2.5 rounded-lg text-sm font-bold transition-all shadow-sm active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed hover:bg-emerald-700">
                            <span v-if="paying">⏳ Đang xử lý...</span>
                            <span v-else>✅ Xác nhận đã thu tiền</span>
                        </button>
                    </div>

                    <!-- Paid state -->
                    <div v-else class="mt-3 bg-green-50 border border-green-100 rounded-lg py-2 text-center">
                        <p class="text-emerald-700 font-bold text-sm">✅ Đã thu [[ (inv._received||0).toLocaleString() ]]đ</p>
                        <p v-if="inv._received > inv.totalAmount" class="text-xs text-slate-500 mt-0.5">Trả lại: [[ (inv._received - inv.totalAmount).toLocaleString() ]]đ</p>
                    </div>
                </div>
                <div v-if="!cashierList.length" class="text-center text-slate-400 text-sm py-8">Không có hóa đơn chờ 🎉</div>
            </div>
        </div>
    </div>

    <!-- LIST VIEW -->
    <div v-if="view==='list'">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="p-5 border-b border-slate-100 bg-slate-50/50">
                <input type="text" v-model="search" placeholder="Tìm tên, SĐT bệnh nhân..."
                       class="text-sm border border-slate-200 rounded-lg px-4 py-2 w-72 focus:ring-2 focus:ring-brand-primary focus:outline-none" />
            </div>
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider border-b border-slate-200">
                        <th class="px-6 py-4 font-semibold">Mã</th>
                        <th class="px-6 py-4 font-semibold">Bệnh nhân</th>
                        <th class="px-6 py-4 font-semibold">Giờ</th>
                        <th class="px-6 py-4 font-semibold">Dịch vụ</th>
                        <th class="px-6 py-4 font-semibold">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    <tr v-for="p in filteredAll" :key="p.id" class="hover:bg-slate-50 transition-colors">
                        <td class="px-6 py-4 font-mono text-sm text-slate-500">#[[ String(p.id).padStart(3,'0') ]]</td>
                        <td class="px-6 py-4">
                            <p class="text-sm font-bold text-slate-900">[[ p.name ]]</p>
                            <p class="text-xs text-slate-400">[[ p.phone ]]</p>
                        </td>
                        <td class="px-6 py-4 text-sm text-slate-700">[[ p.time ]]</td>
                        <td class="px-6 py-4 text-sm text-slate-700">[[ p.service ]]</td>
                        <td class="px-6 py-4">
                            <span :class="{
                                'bg-amber-100 text-amber-700': p.status==='pending',
                                'bg-teal-100 text-teal-700':  p.status==='active',
                                'bg-blue-100 text-blue-700':  p.status==='cashier',
                                'bg-green-100 text-green-700':p.status==='done'
                            }" class="text-xs font-bold px-3 py-1 rounded-full">
                                [[ {pending:'Chờ khám',active:'Đang khám',cashier:'Chờ thu',done:'Hoàn tất'}[p.status] ]]
                            </span>
                        </td>
                    </tr>
                    <tr v-if="!filteredAll.length">
                        <td colspan="5" class="px-6 py-12 text-center text-slate-400">Không có lịch hẹn nào hôm nay.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
const { createApp, ref, computed, onMounted } = Vue;
createApp({
    delimiters: ['[[', ']]'],
    setup() {
        const view   = ref('kanban');
        const search = ref('');
        const loading = ref(true);

        // Checkin states
        const checkinCode = ref('');
        const checkinMsg  = ref('');
        const checkinOk   = ref(false);

        // Real data from DB
        const allPatients = ref([]);
        const pendingInvoices = ref([]);
        const paying = ref(false);

        // Fetch today's appointments from API
        const loadData = async () => {
            try {
                // Fetch Appointments
                const resA  = await fetch('/api/appointmentsapi/today');
                const dataA = await resA.json();
                allPatients.value = dataA.map(a => ({
                    id:      a.appointmentId,
                    name:    a.patientName,
                    phone:   a.patientPhone,
                    time:    a.time,
                    date:    a.date,
                    service: '',
                    doctor:  a.doctorName,
                    room:    '',
                    amount:  '',
                    status:  a.status === 'Pending'   ? 'pending'   :
                             a.status === 'Confirmed' ? 'active'    :
                             a.status === 'Completed' ? 'cashier'   : 'done'
                }));

                // Fetch Pending Invoices for cashier col
                const resI = await fetch('/api/invoicesapi?status=Pending');
                const dataI = await resI.json();
                pendingInvoices.value = dataI;

            } catch (e) {
                console.error('Failed to load data', e);
            }
            loading.value = false;
        };

        onMounted(() => {
            loadData();
            // Auto-refresh every 30s so receptionist sees doctor updates
            setInterval(loadData, 30_000);
        });

        const patchStatus = async (id, newStatus) => {
            await fetch(`/api/appointmentsapi/${id}/status`, {
                method:  'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
        };

        const pendingList = computed(() => allPatients.value.filter(p => p.status === 'pending'));
        const activeList  = computed(() => allPatients.value.filter(p => p.status === 'active'));
        // cashierList = Completed appointments (doctor done) + pending invoices merged
        const cashierList = computed(() => {
            const fromAppts = allPatients.value
                .filter(p => p.status === 'cashier')
                .map(p => ({ invoiceId: null, patientName: p.name, totalAmount: 0, paymentStatus: 'Pending', _apptId: p.id }));
            // Merge: avoid duplicates if invoice already created for same patient
            const invoiceNames = new Set(pendingInvoices.value.map(i => i.patientName));
            const uniqueAppts  = fromAppts.filter(a => !invoiceNames.has(a.patientName));
            return [...uniqueAppts, ...pendingInvoices.value];
        });
        const filteredAll = computed(() => {
            const q = search.value.toLowerCase();
            return !q ? allPatients.value : allPatients.value.filter(p => p.name.toLowerCase().includes(q) || p.phone.includes(q));
        });

        const doCheckin = async () => {
            if (!checkinCode.value.trim()) return;
            const code = checkinCode.value.trim().toLowerCase();
            
            // Tìm trong danh sách chờ (Pending) theo ID (APT-00X) hoặc số CĐ
            const target = pendingList.value.find(p => 
                `apt-${String(p.id).padStart(4,'0')}` === code || 
                `#apt-${String(p.id).padStart(4,'0')}` === code || 
                p.phone === code
            );

            if (target) {
                await callIn(target);
                checkinOk.value = true;
                checkinMsg.value = `Đã check-in thành công cho BN ${target.name}!`;
                checkinCode.value = '';
                setTimeout(() => checkinMsg.value = '', 4000);
            } else {
                checkinOk.value = false;
                checkinMsg.value = "Không tìm thấy bệnh nhân đang chờ với mã/SĐT này.";
            }
        };

        const callIn = async (p) => {
            p.room   = 'Phòng ' + Math.ceil(Math.random() * 3);
            p.status = 'active';
            await patchStatus(p.id, 'Confirmed');
        };
        const moveToCashier = async (p) => {
            // Doctors now ALWAYS create an invoice internally via /complete-exam API
            // So if a Receptionist clicks this manually, just force the frontend update
            p.status = 'done';
            await loadData();
        };

        const payInvoice = async (inv) => {
            if (!inv._received || inv._received <= 0) return;
            paying.value = true;
            try {
                // Only call API if we have a real invoice ID
                if (inv.invoiceId) {
                    const res = await fetch(`/api/invoicesapi/${inv.invoiceId}/collect`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ Method: 'Tiền mặt', AmountReceived: inv._received })
                    });
                    if (!res.ok) {
                        alert('Lỗi khi thu tiền. Vui lòng thử lại.');
                        paying.value = false;
                        return;
                    }
                }
                // Mark paid immediately for UX, then reload in background
                inv._paid = true;
                setTimeout(() => loadData(), 1500);
            } catch (err) {
                alert('Mất kết nối server.');
            }
            paying.value = false;
        };

        return { view, search, loading, checkinCode, checkinMsg, checkinOk,
                 allPatients, pendingList, activeList, cashierList, filteredAll, paying, 
                 doCheckin, callIn, moveToCashier, payInvoice };
    }
}).mount('#app');
</script>
}

