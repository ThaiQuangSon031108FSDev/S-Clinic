@{
    ViewData["Title"] = "Đặt mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var token = ViewData["Token"]?.ToString() ?? "";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-slate-800 to-teal-900 px-4 py-10">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <a href="/" class="inline-flex items-center gap-2 mb-2">
                <div class="w-10 h-10 bg-brand-primary rounded-xl flex items-center justify-center text-white font-extrabold text-lg">S</div>
                <span class="text-2xl font-extrabold text-white">S-Clinic</span>
            </a>
            <p class="text-slate-400 text-sm">Đặt mật khẩu tài khoản nhân sự</p>
        </div>

        <div id="app" class="bg-white rounded-3xl shadow-2xl overflow-hidden">

            <!-- Verifying token... -->
            <div v-if="status === 'checking'" class="p-10 text-center">
                <div class="text-4xl mb-3 animate-pulse">🔑</div>
                <p class="text-slate-500 font-semibold">Đang xác thực link...</p>
            </div>

            <!-- Token invalid / expired -->
            <div v-else-if="status === 'invalid'" class="p-10 text-center">
                <div class="text-5xl mb-4">⛔</div>
                <h2 class="text-xl font-bold text-slate-900 mb-2">Link đã hết hạn</h2>
                <p class="text-slate-500 text-sm mb-6">Link đặt mật khẩu chỉ có hiệu lực trong 24 giờ.<br/>Liên hệ Admin để nhận link mới.</p>
                <a href="/Account/Login" class="inline-block bg-brand-primary text-white px-6 py-3 rounded-2xl font-bold hover:bg-brand-hover transition-colors">
                    Quay lại đăng nhập
                </a>
            </div>

            <!-- Set password form -->
            <div v-else-if="status === 'ready'">
                <div class="bg-gradient-to-r from-teal-600 to-teal-700 p-6 text-white text-center">
                    <div class="text-3xl mb-2">🔐</div>
                    <h2 class="text-xl font-bold">Tạo mật khẩu của bạn</h2>
                    <p class="text-teal-100 text-sm mt-1">Chào mừng bạn đến với S-Clinic</p>
                </div>
                <div class="p-8 space-y-5">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Mật khẩu mới <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input v-model="password" :type="showPw ? 'text' : 'password'"
                                   placeholder="Tối thiểu 8 ký tự"
                                   class="w-full border border-slate-200 rounded-xl px-4 py-3 pr-12 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                            <button type="button" @@click="showPw=!showPw"
                                    class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
                                [[ showPw ? '🙈' : '👁️' ]]
                            </button>
                        </div>
                        <!-- Strength bar -->
                        <div class="flex gap-1 mt-2">
                            <div v-for="n in 4" :key="n"
                                 :class="strength >= n ? ['bg-red-400','bg-amber-400','bg-yellow-400','bg-emerald-500'][n-1] : 'bg-slate-200'"
                                 class="h-1.5 flex-1 rounded-full transition-all"></div>
                        </div>
                        <p class="text-xs mt-1" :class="['text-slate-400','text-red-400','text-amber-500','text-yellow-500','text-emerald-600'][strength]">
                            [[ ['','Quá yếu','Yếu','Khá','Mạnh 💪'][strength] ]]
                        </p>
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-2">Xác nhận mật khẩu <span class="text-red-500">*</span></label>
                        <input v-model="confirm" type="password"
                               placeholder="Nhập lại mật khẩu"
                               :class="confirm && confirm !== password ? 'border-red-400 ring-1 ring-red-400' : 'border-slate-200'"
                               class="w-full border rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                        <p v-if="confirm && confirm !== password" class="text-xs text-red-500 mt-1">⚠️ Mật khẩu không khớp</p>
                    </div>

                    <p v-if="errMsg" class="text-sm text-red-600 bg-red-50 px-4 py-3 rounded-xl border border-red-100">⚠️ [[ errMsg ]]</p>

                    <button @@click="submit" :disabled="!canSubmit || saving"
                            :class="!canSubmit || saving ? 'opacity-50 cursor-not-allowed' : 'hover:bg-brand-hover shadow-md'"
                            class="w-full bg-brand-primary text-white py-3 rounded-xl font-bold text-sm transition-all">
                        <span v-if="saving">⏳ Đang lưu...</span>
                        <span v-else>✓ Xác nhận mật khẩu</span>
                    </button>
                </div>
            </div>

            <!-- Success -->
            <div v-else-if="status === 'done'" class="p-10 text-center">
                <div class="text-6xl mb-4">🎉</div>
                <h2 class="text-2xl font-extrabold text-slate-900 mb-2">Đặt mật khẩu thành công!</h2>
                <p class="text-slate-500 text-sm mb-6">Tài khoản của bạn đã sẵn sàng. Đăng nhập để bắt đầu làm việc.</p>
                <a href="/Account/Login"
                   class="inline-block bg-brand-primary text-white px-8 py-3 rounded-2xl font-bold hover:bg-brand-hover shadow-md transition-colors">
                    Đăng nhập ngay →
                </a>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
const TOKEN = '@token';
const { createApp, ref, computed, onMounted } = Vue;
createApp({
    delimiters: ['[[',']]'],
    setup() {
        const status   = ref('checking');
        const password = ref('');
        const confirm  = ref('');
        const showPw   = ref(false);
        const saving   = ref(false);
        const errMsg   = ref('');

        onMounted(async () => {
            try {
                const res  = await fetch(`/api/admin/verify-set-password-token?token=${TOKEN}`);
                const data = await res.json();
                status.value = data.valid ? 'ready' : 'invalid';
            } catch {
                status.value = 'invalid';
            }
        });

        const strength = computed(() => {
            const p = password.value;
            let s = 0;
            if (p.length >= 8)            s++;
            if (/[A-Z]/.test(p))          s++;
            if (/\d/.test(p))             s++;
            if (/[^A-Za-z0-9]/.test(p))   s++;
            return s;
        });

        const canSubmit = computed(() =>
            password.value.length >= 8 &&
            strength.value >= 2 &&
            password.value === confirm.value
        );

        const submit = async () => {
            errMsg.value = '';
            if (!canSubmit.value) return;
            saving.value = true;
            try {
                const res  = await fetch('/api/admin/set-password', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body:    JSON.stringify({ token: TOKEN, password: password.value })
                });
                const data = await res.json();
                if (data.success) status.value = 'done';
                else errMsg.value = data.message || 'Lỗi không xác định.';
            } catch {
                errMsg.value = 'Lỗi kết nối server.';
            }
            saving.value = false;
        };

        return { status, password, confirm, showPw, strength, canSubmit, saving, errMsg, submit };
    }
}).mount('#app');
</script>
}
