@{
    ViewData["Title"] = "Khám bệnh";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<div id="app" class="grid grid-cols-1 lg:grid-cols-3 gap-6" style="height:calc(100vh - 170px)">

    <!-- LEFT: Patient card -->
    <div class="col-span-1 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col overflow-hidden">
        <!-- Appointment selector -->
        <div class="p-3 border-b border-slate-100 bg-slate-50">
            <select @@change="e => { const id = parseInt(e.target.value); const a = appointments.find(a => a.appointmentId === id); if(a) selectAppt(a); }"
                    class="w-full text-sm border border-slate-200 rounded-xl px-3 py-2 focus:outline-none focus:border-brand-primary bg-white">
                <option value="">-- Chọn bệnh nhân --</option>
                <option v-for="a in appointments" :key="a.appointmentId"
                        :value="a.appointmentId"
                        :selected="selected?.appointmentId === a.appointmentId">
                    [[ a.timeSlot ]] — [[ a.patientName ]] ([[ a.status ]])
                </option>
            </select>
        </div>
        <div class="p-5 border-b border-slate-100 bg-slate-50">
            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Bệnh nhân đang khám</p>
            <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center font-bold text-xl">
                    [[ patient.patientName?.[0] ?? '?' ]]
                </div>
                <div>
                    <h3 class="font-bold text-slate-900 text-lg">[[ patient.patientName ]]</h3>
                    <p class="text-xs text-slate-500">[[ patient.age ? patient.age + ' tuổi' : '' ]] &bull; [[ patient.timeSlot ]]</p>
                </div>
            </div>
        </div>

        <div class="p-5 overflow-y-auto flex-1 space-y-6">
            <div v-if="patient.allergy">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tiền sử dị ứng</h4>
                <p class="text-sm text-red-600 bg-red-50 p-3 rounded-xl border border-red-100 font-medium">
                    ⚠️ [[ patient.allergy ]]
                </p>
            </div>

            <div v-if="patient.packageName">
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Gói điều trị</h4>
                <div class="bg-teal-50 p-3 rounded-xl border border-teal-100">
                    <p class="text-sm font-bold text-teal-800">[[ patient.packageName ]]</p>
                    <p class="text-xs text-teal-600 mt-1">Buổi [[ patient.usedSessions ]]/[[ patient.totalSessions ]]</p>
                    <div class="w-full bg-teal-100 rounded-full h-2 mt-2 overflow-hidden">
                        <div class="bg-brand-primary h-2 rounded-full" :style="{width: (patient.usedSessions/patient.totalSessions*100)+'%'}"></div>
                    </div>
                </div>
            </div>

            <div>
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Timeline Ảnh Da</h4>
                <div class="grid grid-cols-2 gap-2">
                    <div class="relative">
                        <img src="https://images.unsplash.com/photo-1512496015851-a1c8485215f5?auto=format&fit=crop&w=300&q=80"
                             class="rounded-xl border border-slate-200 object-cover h-24 w-full" />
                        <span class="absolute bottom-1 left-1 bg-black/60 text-white text-[10px] px-1.5 py-0.5 rounded">Buổi 3</span>
                    </div>
                    <div class="relative">
                        <img src="https://images.unsplash.com/photo-1522337660859-02fbefca4702?auto=format&fit=crop&w=300&q=80"
                             class="rounded-xl border border-slate-200 object-cover h-24 w-full opacity-70" />
                        <span class="absolute bottom-1 left-1 bg-black/60 text-white text-[10px] px-1.5 py-0.5 rounded">Buổi 1</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Medical record form -->
    <div class="col-span-2 bg-white rounded-2xl shadow-sm border border-slate-200 flex flex-col overflow-hidden">
        <div class="p-5 border-b border-slate-100 flex justify-between items-center">
            <h2 class="text-lg font-bold text-slate-800">Phiếu Khám Bệnh — Buổi [[ (patient.usedSessions ?? 0) + 1 ]]</h2>
            <span class="bg-amber-100 text-amber-700 text-xs font-bold px-3 py-1 rounded-full">[[ patient.packageName || 'Khám mới' ]]</span>
        </div>

        <div class="p-6 overflow-y-auto flex-1 space-y-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Ghi chú tình trạng da <span class="text-red-500">*</span></label>
                <textarea v-model="form.skinCondition" rows="3"
                          class="w-full border border-slate-200 rounded-xl p-3 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none resize-none"
                          placeholder="Mụn viêm đã giảm 70%, da bớt đỏ..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Chẩn đoán / Kết luận</label>
                <textarea v-model="form.diagnosis" rows="2"
                          class="w-full border border-slate-200 rounded-xl p-3 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none resize-none"
                          placeholder="Mụn viêm nhẹ, cải thiện rõ rệt sau liệu trình..."></textarea>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-2">Upload Ảnh Thực Tế Buổi này <span class="text-red-500">*</span></label>
                <div class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer hover:border-brand-primary hover:bg-teal-50/30 transition-colors"
                     @@click="triggerUpload">
                    <span class="text-4xl block mb-2">📸</span>
                    <p class="text-sm font-medium text-slate-600">Nhấn để chọn ảnh Before/After</p>
                    <p class="text-xs text-slate-400 mt-1">JPG, PNG — Tối đa 10MB</p>
                    <input ref="fileInput" type="file" accept="image/*" multiple class="hidden" @@change="onFilePicked" />
                </div>
                <div v-if="previewUrls.length" class="flex gap-2 mt-3 flex-wrap">
                    <img v-for="(u,i) in previewUrls" :key="i" :src="u"
                         class="h-20 w-20 object-cover rounded-xl border border-slate-200" />
                </div>
            </div>

            <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                <div class="flex justify-between items-center mb-4">
                    <label class="block text-sm font-bold text-slate-700">Chỉ định thêm (Thuốc / Dịch vụ)</label>
                    <div class="flex gap-2">
                        <button @@click="showAddMedModal = true" class="text-teal-600 border border-teal-200 bg-teal-50 px-3 py-1 rounded-md text-sm font-bold hover:bg-teal-100">+ Thêm thuốc mới</button>
                        <button @@click="addPrescription" class="text-brand-primary text-sm font-bold hover:text-brand-hover">+ Thêm dòng</button>
                    </div>
                </div>
                
                <datalist id="inventory-list">
                    <option v-for="item in inventory" :key="item.type + item.id" :value="item.name">[[ item.type === 'service' ? 'Dịch vụ' : 'Thuốc' ]]</option>
                </datalist>

                <div v-for="(rx, i) in form.prescriptions" :key="i" class="flex gap-3 items-center mb-2">
                    <input v-model="rx.name" list="inventory-list" type="text" placeholder="Gõ tìm thuốc / dịch vụ..."
                           class="flex-1 border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-1 focus:ring-brand-primary focus:outline-none" />
                    <input v-model.number="rx.qty" type="number" min="1"
                           class="w-20 border border-slate-200 rounded-lg px-3 py-2 text-sm text-center focus:ring-1 focus:ring-brand-primary focus:outline-none" />
                    <button @@click="form.prescriptions.splice(i,1)" class="text-red-400 hover:text-red-600 p-1">✕</button>
                </div>
                <p v-if="!form.prescriptions.length" class="text-xs text-slate-400 text-center py-2">Chưa có chỉ định nào.</p>
            </div>
        </div>

        <div class="p-5 border-t border-slate-100 bg-slate-50 space-y-2">
            <div v-if="doneMsg" class="text-emerald-700 bg-emerald-50 border border-emerald-100 text-sm font-semibold px-4 py-2 rounded-xl">[[ doneMsg ]]</div>
            <div v-if="errMsg"  class="text-red-600 bg-red-50 border border-red-100 text-sm font-medium px-4 py-2 rounded-xl">⚠️ [[ errMsg ]]</div>
            <div class="flex justify-between items-center">
                <span v-if="saved" class="text-emerald-600 font-semibold text-sm">✓ Đã lưu nháp</span>
                <span v-else></span>
                <div class="flex gap-3">
                    <button @@click="saveDraft"
                            class="px-6 py-2 border border-slate-300 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-100 transition-colors">
                        Lưu nháp
                    </button>
                    <button @@click="complete"
                            :disabled="!form.skinCondition || completing || !!doneMsg"
                            :class="(!form.skinCondition || completing || doneMsg) ? 'opacity-50 cursor-not-allowed' : 'hover:bg-brand-hover shadow-md'"
                            class="px-6 py-2 bg-brand-primary text-white rounded-xl text-sm font-bold transition-all">
                        <span v-if="completing">⏳ Đang lưu...</span>
                        <span v-else>✓ Hoàn tất Khám →</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ADD MEDICINE MODAL -->
    <div v-if="showAddMedModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex justify-center items-center pointer-events-auto">
        <div class="bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-2xl animate-fade-in pointer-events-auto">
            <div class="flex justify-between items-center p-5 border-b border-slate-100">
                <h3 class="font-bold text-slate-800 text-lg">Thêm Thuốc Mới</h3>
                <button @@click="showAddMedModal = false" class="text-slate-400 hover:text-slate-700 text-xl font-bold">×</button>
            </div>
            <div class="p-6 space-y-4">
                <p v-if="newMedError" class="text-xs text-red-600 bg-red-50 p-2 rounded">[[ newMedError ]]</p>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Tên thuốc</label>
                    <input v-model="newMed.MedicineName" type="text" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-1 focus:ring-brand-primary focus:outline-none" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-slate-700 mb-1">Danh mục</label>
                    <select v-model="newMed.CategoryId" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-1 focus:ring-brand-primary focus:outline-none">
                        <option value="">-- Chọn danh mục --</option>
                        <option v-for="c in categories" :key="c.categoryId" :value="c.categoryId">[[ c.categoryName ]]</option>
                    </select>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Số lượng</label>
                        <input v-model.number="newMed.StockQuantity" type="number" min="0" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-1 focus:ring-brand-primary focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-sm font-bold text-slate-700 mb-1">Giá bán</label>
                        <input v-model.number="newMed.Price" type="number" min="0" class="w-full border border-slate-200 rounded-lg px-3 py-2 text-sm focus:ring-1 focus:ring-brand-primary focus:outline-none" />
                    </div>
                </div>
            </div>
            <div class="p-5 border-t border-slate-100 flex justify-end gap-3 bg-slate-50">
                <button @@click="showAddMedModal = false" class="px-5 py-2 rounded-xl text-sm font-bold text-slate-600 border border-slate-300 hover:bg-slate-100">Hủy</button>
                <button @@click="saveNewMedicine" :disabled="savingMed" class="px-5 py-2 rounded-xl text-sm font-bold bg-brand-primary text-white hover:bg-brand-hover shadow-md disabled:opacity-50">
                    [[ savingMed ? 'Đang lưu...' : 'Lưu thuốc' ]]
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const { createApp, ref, computed, onMounted } = Vue;
createApp({
    delimiters: ['[[', ']]'],
    setup() {
        // ── State ────────────────────────────────────────────────────────
        const appointments = ref([]);
        const inventory    = ref([]);
        const categories   = ref([]);
        const showAddMedModal = ref(false);
        const newMed = ref({ MedicineName: '', CategoryId: '', StockQuantity: 10, Price: 0 });
        const newMedError = ref('');
        const savingMed = ref(false);

        const selected     = ref(null);
        const fileInput    = ref(null);
        const pickedFiles  = ref([]);
        const previewUrls  = ref([]);
        const saved        = ref(false);
        const saving       = ref(false);
        const completing   = ref(false);
        const doneMsg      = ref('');
        const errMsg       = ref('');

        const form = ref({ skinCondition: '', diagnosis: '', prescriptions: [] });

        // ── Patient shorthand ─────────────────────────────────────────────
        const patient = computed(() => selected.value ?? {
            patientName:'—', age:null, allergy:'', packageName:null,
            usedSessions:0, totalSessions:0, timeSlot:'—', appointmentId:null
        });

        // ── Load Dropdowns and Setup ──────────────────────────────────────
        const loadInventory = async () => {
            try {
                const res = await fetch('/api/doctor/inventory');
                inventory.value = await res.json();
            } catch (e) {
                console.error("Lỗi get inventory", e);
            }
        };
        const loadCategories = async () => {
            try {
                const res = await fetch('/api/medicinesapi/categories');
                categories.value = await res.json();
            } catch (e) {}
        };

        onMounted(async () => {
            loadInventory();
            loadCategories();
            try {
                const res  = await fetch('/api/doctor/today-appointments');
                const data = await res.json();
                appointments.value = data;
                // Auto-select first Confirmed/Pending appointment
                const first = data.find(a => a.status === 'Confirmed' || a.status === 'Pending');
                if (first) selectAppt(first);
            } catch (e) {
                errMsg.value = 'Không thể tải lịch hẹn.';
            }
        });

        const selectAppt = (appt) => {
            selected.value = appt;
            form.value = { skinCondition: '', diagnosis: '', prescriptions: [] };
            pickedFiles.value = [];
            previewUrls.value = [];
            saved.value = false;
            doneMsg.value = '';
            errMsg.value = '';
        };

        // ── Add Fast Medicine ─────────────────────────────────────────────
        const saveNewMedicine = async () => {
            if (!newMed.value.MedicineName || !newMed.value.CategoryId) {
                newMedError.value = "Tên thuốc và danh mục bắt buộc nhập.";
                return;
            }
            savingMed.value = true;
            try {
                const res = await fetch('/api/medicinesapi', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        MedicineName: newMed.value.MedicineName,
                        CategoryId: parseInt(newMed.value.CategoryId),
                        StockQuantity: parseInt(newMed.value.StockQuantity),
                        Price: parseFloat(newMed.value.Price)
                    })
                });
                
                if (res.ok) {
                    const added = await res.json();
                    showAddMedModal.value = false;
                    newMed.value = { MedicineName: '', CategoryId: '', StockQuantity: 10, Price: 0 };
                    // re-fetch inventory
                    loadInventory();
                } else {
                    newMedError.value = "Lỗi. Không thể lưu thuốc.";
                }
            } catch (e) {
                newMedError.value = "Vui lòng xem lại kết nối mạng...";
            }
            savingMed.value = false;
        };

        // ── Photo ─────────────────────────────────────────────────────────
        const triggerUpload = () => fileInput.value?.click();
        const onFilePicked  = (e) => {
            pickedFiles.value = Array.from(e.target.files);
            previewUrls.value = pickedFiles.value.map(f => URL.createObjectURL(f));
        };

        // ── Prescription ──────────────────────────────────────────────────
        const addPrescription = () => form.value.prescriptions.push({ name:'', qty:1 });

        // ── Save draft (local only) ───────────────────────────────────────
        const saveDraft = () => { saved.value = true; setTimeout(() => saved.value = false, 3000); };

        // ── Complete exam → POST API ──────────────────────────────────────
        const complete = async () => {
            if (!form.value.skinCondition || !selected.value?.appointmentId) return;
            completing.value = true;
            errMsg.value = '';

            const fd = new FormData();
            fd.append('AppointmentId',  selected.value.appointmentId);
            fd.append('SkinCondition',  form.value.skinCondition);
            fd.append('Diagnosis',      form.value.diagnosis);
            if (pickedFiles.value.length)
                fd.append('Photo', pickedFiles.value[0]);

            // Prescriptions mapping to MedicineId / ServiceId safely
            form.value.prescriptions.forEach((rx, idx) => {
                if(!rx.name) return;
                const match = inventory.value.find(iv => iv.name.toLowerCase() === rx.name.trim().toLowerCase());
                
                if(match) {
                    fd.append(`Items[${idx}].Type`, match.type);
                    if(match.type === 'service') {
                        fd.append(`Items[${idx}].ServiceId`, match.id);
                    } else {
                        fd.append(`Items[${idx}].MedicineId`, match.id);
                    }
                } else {
                    // Fallback to unknown / text note
                    fd.append(`Items[${idx}].Type`, 'medicine');
                }
                fd.append(`Items[${idx}].Qty`, rx.qty);
            });

            try {
                const res  = await fetch('/api/doctor/complete-exam', { method:'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    doneMsg.value = '✅ Hoàn tất khám! Hóa đơn đã chuyển sang Thu ngân.';
                    // Update appointment status locally
                    const appt = appointments.value.find(a => a.appointmentId === selected.value.appointmentId);
                    if (appt) appt.status = 'Completed';
                } else {
                    errMsg.value = data.message || 'Lỗi khi hoàn tất.';
                }
            } catch {
                errMsg.value = 'Lỗi kết nối đến server.';
            }
            completing.value = false;
        };

        const statusColor = (s) => ({
            'Pending':   'bg-amber-100 text-amber-700',
            'Confirmed': 'bg-blue-100 text-blue-700',
            'Completed': 'bg-green-100 text-green-700',
            'Cancelled': 'bg-slate-100 text-slate-500',
        }[s] ?? 'bg-slate-100 text-slate-500');

        return { appointments, inventory, categories, selected, patient, form, fileInput, pickedFiles, previewUrls,
                 saved, saving, completing, doneMsg, errMsg,
                 showAddMedModal, newMed, newMedError, savingMed, saveNewMedicine,
                 selectAppt, triggerUpload, onFilePicked, addPrescription, saveDraft, complete, statusColor };
    }
}).mount('#app');
</script>
}
