@{
    ViewData["Title"] = "Lịch làm việc";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<style>
[v-cloak] { display: none !important; }
</style>

<div id="app" v-cloak>
    <!-- Week navigation -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <button @@click="prevWeek" class="p-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">◀</button>
            <h2 class="text-lg font-bold text-slate-800">Tuần: [[ weekLabel ]]</h2>
            <button @@click="nextWeek" class="p-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">▶</button>
        </div>
        <div class="flex gap-2">
            <button @@click="goToday" class="px-4 py-2 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-semibold hover:bg-slate-50 transition-colors">
                Hôm nay
            </button>
            <button @@click="showCreateModal=true"
                    class="px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-bold hover:bg-brand-hover transition-colors">
                + Tạo ca làm việc
            </button>
        </div>
    </div>

    <!-- Weekly calendar grid -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="grid grid-cols-8 border-b border-slate-200">
            <div class="p-4 text-xs font-bold text-slate-400 uppercase border-r border-slate-200">Giờ</div>
            <div v-for="(day, i) in weekDays" :key="i"
                 :class="isToday(day.date) ? 'bg-teal-50' : ''"
                 class="p-4 text-center border-r border-slate-200 last:border-r-0">
                <p class="text-xs font-bold text-slate-400 uppercase">[[ day.label ]]</p>
                <p :class="isToday(day.date) ? 'bg-brand-primary text-white w-8 h-8 rounded-full mx-auto flex items-center justify-center' : 'text-slate-800'"
                   class="text-sm font-extrabold mt-1">[[ day.num ]]</p>
            </div>
        </div>

        <!-- Time rows -->
        <div v-for="slot in timeRows" :key="slot" class="grid grid-cols-8 border-b border-slate-100 last:border-b-0" style="min-height:56px">
            <div class="px-4 py-3 text-xs text-slate-400 font-mono border-r border-slate-200 flex items-start">[[ slot ]]</div>
            <div v-for="(day, i) in weekDays" :key="i"
                 class="px-2 py-2 border-r border-slate-100 last:border-r-0 relative">
                <div v-for="appt in getAppts(day.date, slot)" :key="appt.id"
                     :class="{
                         'bg-teal-50 border-teal-200 text-teal-800':    appt.status === 'Confirmed',
                         'bg-green-50 border-green-200 text-green-800':  appt.status === 'Completed',
                         'bg-amber-50 border-amber-200 text-amber-800':  appt.status === 'Pending',
                     }"
                     class="border rounded-lg px-2 py-1.5 text-xs font-semibold mb-1">
                    <p class="font-bold truncate">[[ appt.patient ]]</p>
                    <p class="opacity-70 text-[10px] mb-1">[[ appt.service ]]</p>
                    <!-- Action button for Confirmed appointments -->
                    <a v-if="appt.status === 'Confirmed'"
                       :href="`/Doctor/MedicalRecord/${appt.id}`"
                       class="block w-full text-center bg-teal-600 hover:bg-teal-700 text-white text-[10px] font-bold py-0.5 rounded mt-1 transition-colors">
                        ▶ Tiến hành khám
                    </a>
                    <span v-else-if="appt.status === 'Completed'"
                          class="block text-center text-[10px] text-green-600 font-bold mt-1">✓ Xong</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend -->
    <div class="mt-4 flex gap-4 text-xs text-slate-500">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-teal-200 inline-block"></span> Lịch hẹn xác nhận</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-amber-200 inline-block"></span> Chờ xác nhận</span>
    </div>

    <!-- Create Schedule Modal (inside #app so Vue can control it) -->
    <div v-if="showCreateModal" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md">
            <div class="p-6 border-b border-slate-100">
                <h3 class="text-lg font-bold text-slate-900">+ Tạo ca làm việc</h3>
                <p class="text-xs text-slate-400 mt-0.5">Hệ thống sẽ kiểm tra trùng lặp tự động</p>
            </div>
            <div class="p-6 space-y-4">
                <!-- Mode toggle -->
                <div class="flex bg-slate-100 rounded-xl p-1">
                    <button @@click="createMode='single'"
                            :class="createMode==='single' ? 'bg-white shadow-sm font-bold text-slate-900' : 'text-slate-500'"
                            class="flex-1 py-1.5 text-sm rounded-lg transition-all">Từng ca</button>
                    <button @@click="createMode='bulk'"
                            :class="createMode==='bulk' ? 'bg-white shadow-sm font-bold text-slate-900' : 'text-slate-500'"
                            class="flex-1 py-1.5 text-sm rounded-lg transition-all">Cả tuần</button>
                </div>

                <!-- Single mode -->
                <div v-if="createMode==='single'" class="space-y-3">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Ngày làm việc *</label>
                        <input v-model="schedForm.date" type="date" :min="todayStr"
                               class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Khung giờ *</label>
                        <select v-model="schedForm.timeSlot"
                                class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none">
                            <option value="">-- Chọn giờ --</option>
                            <option v-for="t in allTimeSlots" :key="t" :value="t">[[ t ]]</option>
                        </select>
                    </div>
                </div>

                <!-- Bulk mode -->
                <div v-if="createMode==='bulk'" class="space-y-3">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Từ ngày *</label>
                            <input v-model="schedForm.date" type="date" :min="todayStr"
                                   class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Số ngày</label>
                            <input v-model.number="schedForm.daysCount" type="number" min="1" max="30"
                                   class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-2">Khung giờ (chọn nhiều)</label>
                        <div class="grid grid-cols-4 gap-1.5">
                            <button v-for="t in allTimeSlots" :key="t"
                                    @@click="toggleBulkSlot(t)"
                                    :class="schedForm.bulkSlots.includes(t) ? 'bg-brand-primary text-white border-brand-primary' : 'border-slate-200 text-slate-600 hover:border-brand-primary/50'"
                                    class="py-1.5 text-[11px] font-semibold border rounded-lg transition-all">
                                [[ t ]]
                            </button>
                        </div>
                    </div>
                    <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
                        <input type="checkbox" v-model="schedForm.skipSunday" class="rounded">
                        Bỏ qua Chủ nhật
                    </label>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Số BN tối đa / ca</label>
                    <input v-model.number="schedForm.maxPatients" type="number" min="1" max="10"
                           class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:ring-2 focus:ring-brand-primary focus:outline-none" />
                </div>

                <p v-if="schedError" class="text-xs text-red-500">⚠️ [[ schedError ]]</p>
                <p v-if="schedSuccess" class="text-xs text-emerald-600 font-semibold">✅ [[ schedSuccess ]]</p>
            </div>
            <div class="flex justify-end gap-3 p-6 pt-0">
                <button @@click="showCreateModal=false; schedError=''; schedSuccess=''"
                        class="px-5 py-2.5 border border-slate-200 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-50">
                    Đóng
                </button>
                <button @@click="doCreateSchedule" :disabled="schedSaving"
                        class="px-5 py-2.5 bg-brand-primary text-white rounded-xl text-sm font-bold hover:bg-brand-hover shadow-sm disabled:opacity-50">
                    <span v-if="schedSaving">Đang tạo...</span>
                    <span v-else>Tạo ca</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const { createApp, ref, computed, onMounted } = Vue;
createApp({
    delimiters: ['[[',']]'],
    setup() {
        const baseDate = ref(new Date());

        const timeRows = ['08:00','08:30','09:00','09:30','10:00','10:30',
                          '13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00'];

        const appointments = ref([]);

        const weekDays = computed(() => {
            const start = new Date(baseDate.value);
            const day   = start.getDay();
            const diff  = day === 0 ? -6 : 1 - day;
            start.setDate(start.getDate() + diff);
            return Array.from({length:7}, (_, i) => {
                const d = new Date(start);
                d.setDate(d.getDate() + i);
                return {
                    date:  d.toISOString().split('T')[0],
                    label: ['T2','T3','T4','T5','T6','T7','CN'][i],
                    num:   d.getDate()
                };
            });
        });

        const weekLabel = computed(() => {
            const days = weekDays.value;
            return `${days[0].num}/${String(new Date(days[0].date).getMonth()+1).padStart(2,'0')} – ${days[6].num}/${String(new Date(days[6].date).getMonth()+1).padStart(2,'0')}`;
        });

        // Load appointments for entire visible week
        const loadWeek = async () => {
            try {
                const res  = await fetch('/api/doctor/week-appointments');
                const data = await res.json();
                appointments.value = data.map(a => ({
                    id:      a.appointmentId,
                    date:    a.date,       // yyyy-MM-dd
                    time:    a.timeSlot,   // HH:mm
                    patient: a.patientName,
                    service: a.packageName || 'Khám',
                    status:  a.status
                }));
            } catch {
                // Silently fail — calendar shows empty
            }
        };

        onMounted(loadWeek);

        const isToday = (dateStr) => dateStr === new Date().toISOString().split('T')[0];
        const getAppts = (date, slotTime) => appointments.value.filter(a => {
            if (a.date !== date) return false;
            const [sh, sm] = slotTime.split(':').map(Number);
            const [ah, am] = a.time.split(':').map(Number);
            const slotMin  = sh * 60 + sm;
            const apptMin  = ah * 60 + am;
            return apptMin >= slotMin && apptMin < slotMin + 30;
        });

        const prevWeek = () => { const d = new Date(baseDate.value); d.setDate(d.getDate()-7); baseDate.value = d; loadWeek(); };
        const nextWeek = () => { const d = new Date(baseDate.value); d.setDate(d.getDate()+7); baseDate.value = d; loadWeek(); };
        const goToday  = () => { baseDate.value = new Date(); loadWeek(); };

        // ── Schedule creation ───────────────────────────────────────────────
        const allTimeSlots   = ['08:00','08:30','09:00','09:30','10:00','10:30',
                                '13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00'];
        const todayStr       = new Date().toISOString().split('T')[0];
        const showCreateModal = ref(false);
        const createMode     = ref('single');
        const schedSaving    = ref(false);
        const schedError     = ref('');
        const schedSuccess   = ref('');
        const schedForm      = ref({ date: todayStr, timeSlot: '', maxPatients: 2, bulkSlots: [], daysCount: 7, skipSunday: true });

        const toggleBulkSlot = (t) => {
            const idx = schedForm.value.bulkSlots.indexOf(t);
            if (idx === -1) schedForm.value.bulkSlots.push(t);
            else schedForm.value.bulkSlots.splice(idx, 1);
        };

        const doCreateSchedule = async () => {
            schedError.value = ''; schedSuccess.value = '';
            if (!schedForm.value.date) { schedError.value = 'Chọn ngày làm việc.'; return; }
            if (createMode.value === 'single' && !schedForm.value.timeSlot) { schedError.value = 'Chọn khung giờ.'; return; }
            if (createMode.value === 'bulk' && !schedForm.value.bulkSlots.length) { schedError.value = 'Chọn ít nhất 1 khung giờ.'; return; }

            schedSaving.value = true;
            try {
                let res, data;
                if (createMode.value === 'single') {
                    res  = await fetch('/api/doctor/schedules', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ date: schedForm.value.date, timeSlot: schedForm.value.timeSlot, maxPatients: schedForm.value.maxPatients })
                    });
                    data = await res.json();
                    if (data.success) { schedSuccess.value = 'Tạo ca thành công!'; loadWeek(); }
                    else schedError.value = data.message;
                } else {
                    res  = await fetch('/api/doctor/schedules/bulk', {
                        method: 'POST', headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ startDate: schedForm.value.date, daysCount: schedForm.value.daysCount, timeSlots: schedForm.value.bulkSlots, maxPatients: schedForm.value.maxPatients, skipSunday: schedForm.value.skipSunday })
                    });
                    data = await res.json();
                    if (data.success) { schedSuccess.value = `Đã tạo ${data.created} ca thành công!`; loadWeek(); }
                    else schedError.value = data.message;
                }
            } catch { schedError.value = 'Lỗi kết nối server.'; }
            schedSaving.value = false;
        };

        return { timeRows, weekDays, weekLabel, appointments, isToday, getAppts, prevWeek, nextWeek, goToday,
                 showCreateModal, createMode, schedForm, schedSaving, schedError, schedSuccess,
                 allTimeSlots, todayStr, toggleBulkSlot, doCreateSchedule };
    }
}).mount('#app');
</script>
}
