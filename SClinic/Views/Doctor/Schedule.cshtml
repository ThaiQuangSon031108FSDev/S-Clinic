@{
    ViewData["Title"] = "Lịch làm việc";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
}

<div id="app">
    <!-- Week navigation -->
    <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-3">
            <button @@click="prevWeek" class="p-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">◀</button>
            <h2 class="text-lg font-bold text-slate-800">Tuần: [[ weekLabel ]]</h2>
            <button @@click="nextWeek" class="p-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors">▶</button>
        </div>
        <button @@click="goToday" class="px-4 py-2 bg-brand-primary text-white rounded-lg text-sm font-semibold hover:bg-brand-hover transition-colors">
            Hôm nay
        </button>
    </div>

    <!-- Weekly calendar grid -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="grid grid-cols-8 border-b border-slate-200">
            <div class="p-4 text-xs font-bold text-slate-400 uppercase border-r border-slate-200">Giờ</div>
            <div v-for="(day, i) in weekDays" :key="i"
                 :class="isToday(day.date) ? 'bg-teal-50' : ''"
                 class="p-4 text-center border-r border-slate-200 last:border-r-0">
                <p class="text-xs font-bold text-slate-400 uppercase">[[ day.label ]]</p>
                <p :class="isToday(day.date) ? 'bg-brand-primary text-white w-8 h-8 rounded-full mx-auto flex items-center justify-center' : 'text-slate-800'"
                   class="text-sm font-extrabold mt-1">[[ day.num ]]</p>
            </div>
        </div>

        <!-- Time rows -->
        <div v-for="slot in timeRows" :key="slot" class="grid grid-cols-8 border-b border-slate-100 last:border-b-0" style="min-height:56px">
            <div class="px-4 py-3 text-xs text-slate-400 font-mono border-r border-slate-200 flex items-start">[[ slot ]]</div>
            <div v-for="(day, i) in weekDays" :key="i"
                 class="px-2 py-2 border-r border-slate-100 last:border-r-0 relative">
                <div v-for="appt in getAppts(day.date, slot)" :key="appt.id"
                     :class="{
                         'bg-teal-50 border-teal-200 text-teal-800':    appt.status === 'Confirmed',
                         'bg-green-50 border-green-200 text-green-800':  appt.status === 'Completed',
                         'bg-amber-50 border-amber-200 text-amber-800':  appt.status === 'Pending',
                     }"
                     class="border rounded-lg px-2 py-1.5 text-xs font-semibold mb-1">
                    <p class="font-bold truncate">[[ appt.patient ]]</p>
                    <p class="opacity-70 text-[10px] mb-1">[[ appt.service ]]</p>
                    <!-- Action button for Confirmed appointments -->
                    <a v-if="appt.status === 'Confirmed'"
                       :href="`/Doctor/MedicalRecord/${appt.id}`"
                       class="block w-full text-center bg-teal-600 hover:bg-teal-700 text-white text-[10px] font-bold py-0.5 rounded mt-1 transition-colors">
                        ▶ Tiến hành khám
                    </a>
                    <span v-else-if="appt.status === 'Completed'"
                          class="block text-center text-[10px] text-green-600 font-bold mt-1">✓ Xong</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Legend -->
    <div class="mt-4 flex gap-4 text-xs text-slate-500">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-teal-200 inline-block"></span> Lịch hẹn xác nhận</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-amber-200 inline-block"></span> Chờ xác nhận</span>
    </div>
</div>

@section Scripts {
<script>
const { createApp, ref, computed, onMounted } = Vue;
createApp({
    delimiters: ['[[',']]'],
    setup() {
        const baseDate = ref(new Date());

        const timeRows = ['08:00','08:30','09:00','09:30','10:00','10:30','14:00','14:30','15:00','15:30','16:00','16:30'];
        const appointments = ref([]);

        const weekDays = computed(() => {
            const start = new Date(baseDate.value);
            const day   = start.getDay();
            const diff  = day === 0 ? -6 : 1 - day;
            start.setDate(start.getDate() + diff);
            return Array.from({length:7}, (_, i) => {
                const d = new Date(start);
                d.setDate(d.getDate() + i);
                return {
                    date:  d.toISOString().split('T')[0],
                    label: ['T2','T3','T4','T5','T6','T7','CN'][i],
                    num:   d.getDate()
                };
            });
        });

        const weekLabel = computed(() => {
            const days = weekDays.value;
            return `${days[0].num}/${String(new Date(days[0].date).getMonth()+1).padStart(2,'0')} – ${days[6].num}/${String(new Date(days[6].date).getMonth()+1).padStart(2,'0')}`;
        });

        // Load appointments for entire visible week
        const loadWeek = async () => {
            try {
                const res  = await fetch('/api/doctor/week-appointments');
                const data = await res.json();
                appointments.value = data.map(a => ({
                    id:      a.appointmentId,
                    date:    a.date,       // yyyy-MM-dd
                    time:    a.timeSlot,   // HH:mm
                    patient: a.patientName,
                    service: a.packageName || 'Khám',
                    status:  a.status
                }));
            } catch {
                // Silently fail — calendar shows empty
            }
        };

        onMounted(loadWeek);

        const isToday = (dateStr) => dateStr === new Date().toISOString().split('T')[0];
        const getAppts = (date, slotTime) => appointments.value.filter(a => {
            if (a.date !== date) return false;
            const [sh, sm] = slotTime.split(':').map(Number);
            const [ah, am] = a.time.split(':').map(Number);
            const slotMin  = sh * 60 + sm;
            const apptMin  = ah * 60 + am;
            return apptMin >= slotMin && apptMin < slotMin + 30;
        });

        const prevWeek = () => { const d = new Date(baseDate.value); d.setDate(d.getDate()-7); baseDate.value = d; loadWeek(); };
        const nextWeek = () => { const d = new Date(baseDate.value); d.setDate(d.getDate()+7); baseDate.value = d; loadWeek(); };
        const goToday  = () => { baseDate.value = new Date(); loadWeek(); };

        return { timeRows, weekDays, weekLabel, appointments, isToday, getAppts, prevWeek, nextWeek, goToday };
    }
}).mount('#app');
</script>
}
