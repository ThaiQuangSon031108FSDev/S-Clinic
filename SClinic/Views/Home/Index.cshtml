// ══════════════════════════════════════════════════════════════
// 2. GSAP ScrollTrigger animations
// ══════════════════════════════════════════════════════════════
gsap.registerPlugin(ScrollTrigger);

// Hero text entrance
gsap.from('#hero-text > *', {
    y: 30, opacity: 0, stagger: 0.15, duration: 0.8, ease: 'power2.out', delay: 0.3
});

// Fade-up elements
document.querySelectorAll('.gsap-fade-up').forEach(el => {
    gsap.to(el, {
        y: 0, opacity: 1, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' }
    });
});

// Stagger cards
ScrollTrigger.batch('.gsap-stagger', {
    onEnter: batch => gsap.to(batch, {
        opacity: 1, y: 0, stagger: 0.12, duration: 0.7, ease: 'power2.out'
    }),
    start: 'top 88%'
});

// ══════════════════════════════════════════════════════════════
// 3. BEFORE / AFTER Canvas slider with glow sweep
// ══════════════════════════════════════════════════════════════
(function initBA() {
    const wrap      = document.getElementById('ba-canvas-wrap');
    const afterClip = document.getElementById('ba-after-clip');
    const divider   = document.getElementById('ba-divider');
    const glowCanvas= document.getElementById('glow-canvas');
    if (!wrap) return;

    let dragging = false;
    let pct = 50;

    function setClip(x) {
        const rect = wrap.getBoundingClientRect();
        pct = Math.max(5, Math.min(95, ((x - rect.left) / rect.width) * 100));
        afterClip.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
        divider.style.left = pct + '%';
    }

    function fireGlow(x) {
        const rect = wrap.getBoundingClientRect();
        const cx   = x - rect.left;
        glowCanvas.width  = rect.width;
        glowCanvas.height = rect.height;
        const ctx  = glowCanvas.getContext('2d');
        glowCanvas.style.opacity = '1';

        let alpha = 0.6;
        let frame = 0;
        function draw() {
            ctx.clearRect(0, 0, glowCanvas.width, glowCanvas.height);
            const grad = ctx.createLinearGradient(cx - 30, 0, cx + 30, 0);
            grad.addColorStop(0, `rgba(255,255,255,0)`);
            grad.addColorStop(0.5, `rgba(255,255,255,${alpha})`);
            grad.addColorStop(1, `rgba(255,255,255,0)`);
            ctx.fillStyle = grad;
            ctx.fillRect(0, 0, glowCanvas.width, glowCanvas.height);
            alpha -= 0.015;
            if (alpha > 0 && frame++ < 60) requestAnimationFrame(draw);
            else { glowCanvas.style.opacity = '0'; ctx.clearRect(0,0,glowCanvas.width,glowCanvas.height); }
        }
        draw();
    }

    wrap.addEventListener('mousedown',  e => { dragging = true; setClip(e.clientX); });
    wrap.addEventListener('touchstart', e => { dragging = true; setClip(e.touches[0].clientX); }, { passive: true });

    window.addEventListener('mousemove',  e => { if (dragging) { setClip(e.clientX); fireGlow(e.clientX); } });
    window.addEventListener('touchmove',  e => { if (dragging) { setClip(e.touches[0].clientX); } }, { passive: true });
    window.addEventListener('mouseup',   () => dragging = false);
    window.addEventListener('touchend',  () => dragging = false);
})();

// ══════════════════════════════════════════════════════════════
// 4. DOCTOR CAROUSEL
// ══════════════════════════════════════════════════════════════
const DOCTOR_PHOTOS = [
    'https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=400&h=480&fit=crop&q=80',
    'https://images.unsplash.com/photo-1612349317150-e413f6a5b16d?w=400&h=480&fit=crop&q=80',
    'https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=400&h=480&fit=crop&q=80',
    'https://images.unsplash.com/photo-1582750433449-648ed127bb54?w=400&h=480&fit=crop&q=80',
    'https://images.unsplash.com/photo-1651008376811-b90baee60c1f?w=400&h=480&fit=crop&q=80',
    'https://images.unsplash.com/photo-1622253692010-333f2da6031d?w=400&h=480&fit=crop&q=80',
];

document.addEventListener('DOMContentLoaded', async () => {
    const cardsEl = document.getElementById('doctor-cards');
    const dotsEl  = document.getElementById('slider-dots');
    const prevBtn = document.getElementById('slider-prev');
    const nextBtn = document.getElementById('slider-next');
    if (!cardsEl) return;

    let doctors = [], page = 0, perPage = window.innerWidth >= 768 ? 3 : 1, autoPlay;

    try {
        const res = await fetch('/api/doctorsapi');
        doctors = await res.json();
    } catch (e) {
        cardsEl.innerHTML = '<p class="col-span-3 text-center text-slate-400 py-10">Đang cập nhật...</p>';
        return;
    }

    if (!doctors.length) {
        cardsEl.innerHTML = '<p class="col-span-3 text-center text-slate-400 py-10">Đang cập nhật danh sách bác sĩ...</p>';
        return;
    }

    const totalPages = () => Math.ceil(doctors.length / perPage);

    const rebuildDots = () => {
        dotsEl.innerHTML = '';
        for (let i = 0; i < totalPages(); i++) {
            const dot = document.createElement('button');
            dot.className = `w-2.5 h-2.5 rounded-full transition-all ${i === page ? 'bg-brand-primary scale-125' : 'bg-slate-300'}`;
            dot.addEventListener('click', () => { page = i; render(); resetAutoplay(); });
            dotsEl.appendChild(dot);
        }
    };

    const render = () => {
        perPage = window.innerWidth >= 768 ? 3 : 1;
        if (page >= totalPages()) page = 0;
        cardsEl.style.opacity = '0';
        setTimeout(() => {
            const start = page * perPage;
            const slice = doctors.slice(start, start + perPage);
            cardsEl.innerHTML = slice.map((doc, i) => {
                const photo = DOCTOR_PHOTOS[(start + i) % DOCTOR_PHOTOS.length];
                return `
                <div class="bg-white rounded-3xl overflow-hidden shadow-md border border-slate-100 hover:-translate-y-2 hover:shadow-xl transition-all duration-300 flex flex-col">
                    <div class="relative h-72 bg-slate-100 overflow-hidden">
                        <img src="${photo}" alt="${doc.fullName}" class="w-full h-full object-cover object-top"
                             onerror="this.src='https://placehold.co/400x288/ccfbf1/0f766e?text=BS'">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent"></div>
                        <div class="absolute bottom-3 left-4 right-4">
                            <span class="inline-block bg-brand-primary text-white text-xs font-bold px-3 py-1 rounded-full">${doc.specialty || 'Da liễu chuyên khoa'}</span>
                        </div>
                    </div>
                    <div class="p-5 flex-1 flex flex-col">
                        <h4 class="text-lg font-bold text-slate-900">${doc.fullName}</h4>
                        <p class="text-sm text-slate-500 mt-1 flex-1">Bác sĩ chuyên khoa tại S-Clinic, tận tâm với từng bệnh nhân.</p>
                        <div class="flex items-center gap-2 mt-4">
                            <span class="text-xs bg-teal-50 text-teal-700 border border-teal-100 px-2.5 py-1 rounded-full font-medium">⭐ 5.0</span>
                            <span class="text-xs bg-slate-50 text-slate-600 border border-slate-100 px-2.5 py-1 rounded-full">8+ năm</span>
                        </div>
                    </div>
                </div>`;
            }).join('');
            rebuildDots();
            cardsEl.style.opacity = '1';
        }, 250);
    };

    const resetAutoplay = () => {
        clearInterval(autoPlay);
        autoPlay = setInterval(() => { page = (page + 1) % totalPages(); render(); }, 5000);
    };

    prevBtn.addEventListener('click', () => { page = (page - 1 + totalPages()) % totalPages(); render(); resetAutoplay(); });
    nextBtn.addEventListener('click', () => { page = (page + 1) % totalPages(); render(); resetAutoplay(); });
    window.addEventListener('resize', () => { perPage = window.innerWidth >= 768 ? 3 : 1; render(); });
    render();
    resetAutoplay();
});

