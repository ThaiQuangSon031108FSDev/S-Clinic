window.openServiceModal = function(key) {
    const s = SERVICES[key];
    if (!s) return;

    const bookUrl = `/Account/Login?returnUrl=/Patient/Book?service=${encodeURIComponent(s.bookKey)}`;
    const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
    const role = '@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "")';
    const finalUrl = isAuthenticated && role === 'Patient'
        ? `/Patient/Book?service=${encodeURIComponent(s.bookKey)}`
        : bookUrl;

    document.getElementById('modal-content').innerHTML = `
        <div class="p-6 border-b border-slate-100 flex justify-between items-start">
            <div>
                <span class="inline-block text-xs font-bold px-3 py-1 rounded-full ${s.tagColor} mb-2">${s.tag}</span>
                <h3 class="text-2xl font-extrabold text-slate-900">${s.name}</h3>
            </div>
            <button onclick="closeServiceModal()" class="text-slate-400 hover:text-slate-700 text-2xl font-bold leading-none">&times;</button>
        </div>
        <div class="p-6 space-y-5">
            <div class="grid grid-cols-3 gap-3 text-center">
                <div class="bg-slate-50 p-3 rounded-xl">
                    <p class="text-xs text-slate-500 mb-1">Giá</p>
                    <p class="text-sm font-bold text-brand-primary">${s.price}</p>
                </div>
                <div class="bg-slate-50 p-3 rounded-xl">
                    <p class="text-xs text-slate-500 mb-1">Thời gian</p>
                    <p class="text-sm font-bold text-slate-900">${s.duration}</p>
                </div>
                <div class="bg-slate-50 p-3 rounded-xl">
                    <p class="text-xs text-slate-500 mb-1">Phù hợp</p>
                    <p class="text-xs font-bold text-slate-700 leading-tight">${s.for}</p>
                </div>
            </div>
            <div>
                <h4 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-3">Quy trình thực hiện</h4>
                <ul class="space-y-2">
                    ${s.steps.map(step => `<li class="flex items-start gap-3 text-sm text-slate-600"><span class="text-brand-primary font-bold mt-0.5">▸</span>${step}</li>`).join('')}
                </ul>
            </div>
            <div class="bg-teal-50 border border-teal-100 rounded-xl p-4 text-sm text-teal-800">
                💡 Bạn sẽ được chọn ngày, giờ và bác sĩ phù hợp ở bước tiếp theo. Gói dịch vụ sẽ được chọn sẵn.
            </div>
        </div>
        <div class="p-6 border-t border-slate-100 flex gap-3">
            <button onclick="closeServiceModal()" class="flex-1 py-3 rounded-xl border-2 border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 transition-all">
                Đóng
            </button>
            <a href="${finalUrl}" class="flex-1 py-3 rounded-xl font-bold text-center transition-all shadow-md ${s.ctaClass}">
                ${s.cta} →
            </a>
        </div>
    `;
    document.getElementById('service-modal').classList.add('open');
    document.body.style.overflow = 'hidden';
};

window.closeServiceModal = function() {
    document.getElementById('service-modal').classList.remove('open');
    document.body.style.overflow = '';
};

// Close on backdrop click
document.getElementById('service-modal').addEventListener('click', function(e) {
    if (e.target === this) closeServiceModal();
});

// Escape key
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeServiceModal(); });
</script>
