@section Scripts {
<script>
// ══════════════════════════════════════════════════════════════
// 1. VANTA WAVES — WebGL fluid hero background
// ══════════════════════════════════════════════════════════════
VANTA.WAVES({
    el: '#vanta-bg',
    mouseControls: true,
    touchControls: true,
    gyroControls: false,
    minHeight: 200,
    minWidth: 200,
    scale: 1.0,
    scaleMobile: 1.0,
    color: 0xb2f5ea,        // teal-200
