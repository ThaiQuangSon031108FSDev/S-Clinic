@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
<style>
    /* ── WebGL Hero ── */
    #vanta-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        overflow: hidden;
    }
    #vanta-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    #vanta-hero .hero-content {
        position: relative;
        z-index: 10;
        width: 100%;
    }

    /* ── Before/After Canvas ── */
    #ba-canvas-wrap {
        position: relative;
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
        cursor: col-resize;
        border-radius: 1.25rem;
        overflow: hidden;
        box-shadow: 0 20px 60px -10px rgba(15,118,110,0.25);
    }
    #ba-canvas-wrap img { display: block; width: 100%; height: 300px; object-fit: cover; object-position: top; border-radius: 0; }
    #ba-divider {
        position: absolute;
        top: 0; bottom: 0;
        left: 50%;
        width: 3px;
        background: #0f766e;
        cursor: col-resize;
        z-index: 10;
        transition: left 0.05s;
    }
    #ba-handle {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 40px; height: 40px;
        border-radius: 50%;
        background: #0f766e;
        border: 3px solid white;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 14px; font-weight: bold;
        z-index: 11;
        pointer-events: none;
    }
    #ba-after-clip {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        clip-path: inset(0 50% 0 0);
        z-index: 2;
    }
    #ba-before { position: relative; z-index: 1; }
    #ba-label-before, #ba-label-after {
        position: absolute; bottom: 10px;
        font-size: 11px; font-weight: 700;
        color: white; padding: 2px 10px;
        border-radius: 99px; z-index: 12;
        pointer-events: none;
    }
    #ba-label-before { left: 10px; background: rgba(0,0,0,0.6); }
    #ba-label-after  { right: 10px; background: #0f766e; }

    /* ── Glow sweep canvas ── */
    #glow-canvas {
        position: absolute;
        inset: 0;
        z-index: 20;
        pointer-events: none;
        border-radius: 1.25rem;
        opacity: 0;
        transition: opacity 0.3s;
    }

    /* ── GSAP hidden defaults ── */
    .gsap-fade-up { opacity: 0; transform: translateY(40px); }
    .gsap-stagger { opacity: 0; transform: translateY(30px); }

    /* ── Service Modal ── */
    #service-modal {
        display: none;
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(15,23,42,0.6);
        backdrop-filter: blur(6px);
        align-items: center; justify-content: center;
    }
    #service-modal.open { display: flex; }
    #service-modal-box {
        background: white;
        border-radius: 2rem;
        width: 100%; max-width: 540px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 40px 80px -20px rgba(0,0,0,0.4);
        animation: modalSlideIn 0.35s cubic-bezier(0.22,1,0.36,1);
    }
    @@keyframes modalSlideIn {
        from { opacity:0; transform: scale(0.94) translateY(20px); }
        to   { opacity:1; transform: scale(1) translateY(0); }
    }
</style>
<!-- GSAP + ScrollTrigger -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<!-- Vanta.js WAVES (WebGL) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.waves.min.js"></script>
}

<!-- ── NAVIGATION ───────────────────────────────────────────────────────── -->
<header class="fixed top-0 left-0 right-0 z-50 glass-nav">
    <nav class="container mx-auto px-4 md:px-6 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
            <span class="text-2xl font-extrabold text-brand-primary tracking-tight">S-CLINIC</span>
        </a>
        <div class="hidden md:flex items-center gap-8">
            <a href="#quy-trinh" class="text-slate-900 font-medium hover:text-brand-primary transition-colors">Quy trình</a>
            <a href="#gia-goi"   class="text-slate-900 font-medium hover:text-brand-primary transition-colors">Bảng giá</a>
            <a href="#doi-ngu"   class="text-slate-900 font-medium hover:text-brand-primary transition-colors">Bác sĩ</a>
        </div>
        <div class="flex items-center gap-4">
            @if (User.Identity?.IsAuthenticated == true)
            {
                var role  = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
                var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
                var dashUrl = role switch {
                    "Patient"      => "/Patient/Dashboard",
                    "Doctor"       => "/Doctor/Dashboard",
                    "Receptionist" => "/Receptionist/Dashboard",
                    "Admin"        => "/Admin/Dashboard",
                    "Cashier"      => "/Admin/Finance",
                    _              => "/"
                };
                <a href="@dashUrl" class="hidden sm:flex items-center gap-2 bg-slate-100 hover:bg-teal-50 border border-slate-200 hover:border-brand-primary px-4 py-2 rounded-xl transition-colors">
                    <span class="w-7 h-7 rounded-full bg-brand-primary text-white flex items-center justify-center text-xs font-bold">
                        @email.Substring(0,1).ToUpper()
                    </span>
                    <span class="text-sm font-semibold text-slate-700">Dashboard</span>
                </a>
                <form method="post" asp-controller="Account" asp-action="Logout" class="hidden sm:block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-slate-500 hover:text-red-500 text-sm font-medium transition-colors">Đăng xuất</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   class="hidden sm:block text-slate-900 font-semibold hover:text-brand-primary transition-colors px-2">
                    Đăng nhập
                </a>
                <a asp-controller="Account" asp-action="Register"
                   class="hidden sm:block text-brand-primary border border-brand-primary font-semibold px-4 py-2 rounded-xl hover:bg-teal-50 transition-colors text-sm">
                    Đăng ký
                </a>
            }
            @{
                var bookUrl = User.Identity?.IsAuthenticated == true
                    ? (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Patient" ? "/Patient/Book" : "#")
                    : "/Account/Login?returnUrl=/Patient/Book";
            }
            <a href="@bookUrl"
               class="bg-brand-primary text-white px-6 py-2.5 rounded-full font-semibold hover:bg-brand-hover transition-all shadow-md">
                Đặt lịch khám
            </a>
        </div>
    </nav>
</header>

<main class="pt-20">

    <!-- ── HERO (WebGL WAVES + 2-col layout) ──────────────────────────────── -->
    <section id="vanta-hero">
        <div id="vanta-bg"></div>
        <div class="hero-content container mx-auto px-4 md:px-6 py-16 md:py-28">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                <!-- Left: Copy -->
                <div class="space-y-8" id="hero-text">
                    <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/80 backdrop-blur-sm text-brand-primary border border-teal-200 font-semibold text-sm shadow-sm">
                        ✨ Giải pháp Da liễu chuẩn Y khoa
                    </div>
                    <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 leading-[1.1] drop-shadow-sm">
                        Phục hồi làn da. <br />
                        <span class="text-brand-primary">Không chờ đợi.</span>
                    </h1>
                    <p class="text-lg md:text-xl text-slate-700 max-w-lg leading-relaxed">
                        Hệ thống đặt lịch tự động giúp bạn kết nối ngay với bác sĩ chuyên khoa.
                        Lấy lại vẻ đẹp tự nhiên bằng công nghệ tiên tiến nhất.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="#gia-goi"
                           class="inline-flex items-center justify-center gap-2 bg-brand-primary text-white px-8 py-4 rounded-2xl font-bold text-lg hover:bg-brand-hover transition-all shadow-xl active:scale-95">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            Xí chỗ ngay hôm nay
                        </a>
                        <a href="#doi-ngu"
                           class="inline-flex items-center justify-center gap-2 bg-white/80 backdrop-blur-sm text-slate-800 border border-slate-200 px-8 py-4 rounded-2xl font-bold text-lg hover:bg-white hover:shadow-md transition-all">
                            Gặp bác sĩ →
                        </a>
                    </div>
                    <!-- Quick stats -->
                    <div class="flex gap-8 pt-2">
                        <div>
                            <div class="text-3xl font-extrabold text-brand-primary">2.000+</div>
                            <div class="text-sm text-slate-500 mt-0.5">Bệnh nhân</div>
                        </div>
                        <div class="border-l border-slate-200 pl-8">
                            <div class="text-3xl font-extrabold text-brand-primary">5</div>
                            <div class="text-sm text-slate-500 mt-0.5">Bác sĩ CK</div>
                        </div>
                        <div class="border-l border-slate-200 pl-8">
                            <div class="text-3xl font-extrabold text-brand-primary">98%</div>
                            <div class="text-sm text-slate-500 mt-0.5">Hài lòng</div>
                        </div>
                    </div>
                </div>

                <!-- Right: Doctor photo card -->
                <div class="relative flex justify-center lg:justify-end">
                    <div class="absolute -top-8 -left-8 w-40 h-40 bg-teal-300/30 rounded-full blur-3xl"></div>
                    <div class="absolute -bottom-8 -right-8 w-40 h-40 bg-cyan-200/30 rounded-full blur-3xl"></div>
                    <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl border-4 border-white/80 backdrop-blur-sm w-full max-w-md">
                        <img src="/images/hero-doctor.png"
                             alt="Bác sĩ chuyên khoa S-Clinic"
                             class="w-full h-[480px] object-cover object-top"
                             onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1594824476967-48c8b964273f?w=600&h=700&fit=crop&q=80'">
                        <!-- Floating badge -->
                        <div class="absolute bottom-5 left-5 right-5 bg-white/90 backdrop-blur-sm rounded-2xl p-4 shadow-lg border border-white">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-xl bg-teal-100 flex items-center justify-center text-xl">🩺</div>
                                <div>
                                    <p class="text-xs text-slate-500 font-medium">Đội ngũ bác sĩ</p>
                                    <p class="text-sm font-bold text-slate-900">Da liễu & Thẩm mỹ Y khoa</p>
                                </div>
                                <div class="ml-auto flex -space-x-2">
                                    <img class="w-8 h-8 rounded-full border-2 border-white object-cover" src="https://ui-avatars.com/api/?name=A&background=0f766e&color=fff&size=32">
                                    <img class="w-8 h-8 rounded-full border-2 border-white object-cover" src="https://ui-avatars.com/api/?name=B&background=0d9488&color=fff&size=32">
                                    <img class="w-8 h-8 rounded-full border-2 border-white object-cover" src="https://ui-avatars.com/api/?name=C&background=14b8a6&color=fff&size=32">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ── QUY TRÌNH ─────────────────────────────────────────────────────── -->
    <section class="bg-white py-24" id="quy-trinh">
        <div class="container mx-auto px-4 md:px-6">
            <div class="text-center mb-16 gsap-fade-up">
                <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">3 Bước đơn giản để gặp Bác sĩ</h2>
                <p class="text-slate-600">Quy trình tối giản, tiết kiệm thời gian tối đa cho khách hàng.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                @foreach (var step in new[] {
                    new { Num = "01", Title = "Chọn dịch vụ",    Desc = "Khám tổng quát, điều trị mụn, hoặc các liệu trình trẻ hoá cao cấp.", Icon = "" },
                    new { Num = "02", Title = "Chọn thời gian",  Desc = "Lựa chọn khung giờ phù hợp với lịch trình cá nhân của bạn.", Icon = "" },
                    new { Num = "03", Title = "Xác nhận & Đến",  Desc = "Nhận tin nhắn xác nhận lịch hẹn tức thì qua điện thoại.", Icon = "" },
                }) {
                <div class="gsap-stagger bg-slate-50 p-8 rounded-2xl border border-slate-100 text-center hover:-translate-y-1 hover:shadow-md transition-all duration-300">
                    <div class="text-4xl mb-4">@step.Icon</div>
                    <div class="w-12 h-12 bg-teal-100 text-brand-primary rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <span class="text-lg font-bold">@step.Num</span>
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 mb-3">@step.Title</h3>
                    <p class="text-slate-600">@step.Desc</p>
                </div>
                }
            </div>
        </div>
    </section>

    <!-- ── CASE STUDY (Before/After Canvas) ──────────────────────────────── -->
    <section class="bg-teal-50 py-24" id="case-study">
        <div class="container mx-auto px-4 md:px-6">
            <div class="text-center mb-16 gsap-fade-up">
                <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Câu chuyện khách hàng</h2>
                <p class="text-slate-600">Thành quả sau chuỗi ngày kiên trì điều trị chuẩn y khoa.</p>
            </div>
            <div class="max-w-4xl mx-auto bg-white p-8 rounded-3xl shadow-lg border border-teal-100 flex flex-col md:flex-row items-center gap-10">
                <div class="flex-1">
                    <div class="inline-flex items-center gap-2 bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold px-3 py-1 rounded-full mb-4">
                        ✅ Ca điều trị thực tế — Demo
                    </div>
                    <h3 class="text-2xl font-bold text-slate-800">Nguyễn T*** C***</h3>
                    <p class="text-brand-primary font-semibold mt-2">Liệu trình Trị mụn Y khoa · 10 buổi</p>
                    <ul class="mt-4 space-y-2 text-sm text-slate-600">
                        <li class="flex items-start gap-2"><span class="text-brand-primary font-bold mt-0.5">▸</span> Mụn viêm cấp độ 3, da mẫn cảm, nhiều thâm cũ.</li>
                        <li class="flex items-start gap-2"><span class="text-brand-primary font-bold mt-0.5">▸</span> Lấy nhân mụn y khoa + Chiếu tia sinh học + Điện di Serum.</li>
                        <li class="flex items-start gap-2"><span class="text-brand-primary font-bold mt-0.5">▸</span> Da phục hồi 90%, không để lại sẹo thâm sau 10 buổi.</li>
                    </ul>
                    <p class="mt-5 text-slate-500 italic text-sm border-l-4 border-teal-300 pl-4 leading-relaxed">
                        "Da tôi cải thiện rõ rệt từ buổi thứ 3. Bác sĩ tư vấn rất tận tình."
                    </p>
                    <p class="text-xs text-slate-400 mt-3">← Kéo thanh trượt để so sánh Before/After</p>
                </div>

                <!-- Canvas Before/After -->
                <div class="flex-shrink-0 w-full md:w-auto">
                    <div id="ba-canvas-wrap">
                        <img id="ba-before" src="/images/case-before.png" alt="Trước" onerror="this.src='https://placehold.co/480x300/e2e8f0/64748b?text=Truoc'">
                        <div id="ba-after-clip">
                            <img src="/images/case-after.png" alt="Sau" style="width:100%;height:300px;object-fit:cover;object-position:top;" onerror="this.src='https://placehold.co/480x300/ccfbf1/0f766e?text=Sau'">
                        </div>
                        <div id="ba-divider">
                            <div id="ba-handle">⇔</div>
                        </div>
                        <canvas id="glow-canvas"></canvas>
                        <span id="ba-label-before">NGÀY 1</span>
                        <span id="ba-label-after">BUỔI 10</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── DOCTORS CAROUSEL ─────────────────────────────────────────────── -->
    <section class="bg-white py-24" id="doi-ngu">
        <div class="container mx-auto px-4 md:px-6">
            <div class="text-center mb-16 gsap-fade-up">
                <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Đội ngũ chuyên gia</h2>
                <p class="text-slate-600">Những bác sĩ Da liễu hàng đầu, tận tâm đồng hành cùng bạn.</p>
            </div>
            <div class="relative max-w-6xl mx-auto" id="doctor-section">
                <div id="doctor-cards" class="grid grid-cols-1 md:grid-cols-3 gap-8 transition-opacity duration-500"></div>
                <div class="flex items-center justify-center gap-4 mt-10">
                    <button id="slider-prev" class="w-11 h-11 rounded-full border-2 border-slate-200 flex items-center justify-center text-slate-500 hover:border-brand-primary hover:text-brand-primary transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <div id="slider-dots" class="flex gap-2"></div>
                    <button id="slider-next" class="w-11 h-11 rounded-full border-2 border-slate-200 flex items-center justify-center text-slate-500 hover:border-brand-primary hover:text-brand-primary transition-all">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- ── BẢNG GIÁ + Service Detail Modal ──────────────────────────────── -->
    <section class="bg-slate-50 py-24" id="gia-goi">
        <div class="container mx-auto px-4 md:px-6">
            <div class="text-center mb-16 gsap-fade-up">
                <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Phác đồ điều trị chuyên sâu</h2>
                <p class="text-slate-600">Thiết kế cá nhân hóa cho từng tình trạng da cụ thể.</p>
            </div>

            @{
                var dbServices = ViewBag.Services as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
                var useDb      = dbServices.Any();
                // Fallback static data for demo if DB empty
                var staticCards = new[] {
                    new { Id=0, Name="Khám & Soi Da",             Desc="Dành cho khách hàng mới",       Price=499000m,    Unit="lượt",    Icon="🏥", Badge="",           IsPrimary=false },
                    new { Id=0, Name="Liệu trình Trị mụn Y khoa", Desc="Phục hồi nền da thương tổn",    Price=5500000m,   Unit="5 buổi",  Icon="✨", Badge="Best Seller", IsPrimary=true  },
                    new { Id=0, Name="Nâng cơ Ultra Therapy",      Desc="Trẻ hoá công nghệ cao",         Price=12900000m,  Unit="buổi",    Icon="💎", Badge="Premium",     IsPrimary=false },
                };
            }

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto" id="pricing-grid">

            @if (useDb)
            {
                // ── REAL DB SERVICES ──────────────────────────────────────────
                int idx = 0;
                foreach (var svc in dbServices)
                {
                    bool isPrimary = (idx == 1);
                    <div class="gsap-stagger bg-white p-8 rounded-3xl @(isPrimary ? "border-2 border-brand-primary shadow-lg relative" : "border border-slate-100 shadow-sm hover:shadow-xl") transition-all duration-300 hover:-translate-y-2 flex flex-col">
                        @if (isPrimary)
                        {
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-primary text-white px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider">Best Seller</div>
                        }
                        <div class="flex-1">
                            <h3 class="text-xl font-bold text-slate-900">@svc.ServiceName</h3>
                            <p class="text-sm text-slate-500 mt-2 mb-6">Dịch vụ chuyên khoa da liễu</p>
                            <div class="text-4xl font-extrabold text-slate-900 mb-6">
                                @svc.Price.ToString("N0")đ<span class="text-base font-normal text-slate-500"> / lượt</span>
                            </div>
                        </div>
                        <a href="/Patient/Book?serviceId=@svc.ServiceId"
                           class="w-full py-3 rounded-xl text-center font-bold transition-all block @(isPrimary ? "bg-brand-primary text-white hover:bg-brand-hover shadow-md" : "border-2 border-slate-200 text-slate-700 hover:border-brand-primary hover:text-brand-primary hover:bg-teal-50")">
                            Xem chi tiết & Đặt lịch →
                        </a>
                    </div>
                    idx++;
                }
            }
            else
            {
                // ── FALLBACK STATIC CARDS ─────────────────────────────────────
                foreach (var card in staticCards)
                {
                    <div class="gsap-stagger bg-white p-8 rounded-3xl @(card.IsPrimary ? "border-2 border-brand-primary shadow-lg relative" : "border border-slate-100 shadow-sm hover:shadow-xl") transition-all duration-300 hover:-translate-y-2 flex flex-col">
                        @if (!string.IsNullOrEmpty(card.Badge))
                        {
                            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-brand-primary text-white px-4 py-1 rounded-full text-xs font-bold uppercase tracking-wider">@card.Badge</div>
                        }
                        <div class="flex-1">
                            <h3 class="text-xl font-bold text-slate-900">@card.Name</h3>
                            <p class="text-sm text-slate-500 mt-2 mb-6">@card.Desc</p>
